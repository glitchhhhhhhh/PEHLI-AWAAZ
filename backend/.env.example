# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── LLM Provider (choose one) ──
LLM_PROVIDER=google          # "openai" | "google"
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ── Voice Pipeline ──
STT_MODEL=base               # whisper model: tiny | base | small | medium | large
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC  # Coqui TTS model
VOICE_SAMPLE_RATE=16000

# ── State Engine ──
LEAD_HOT_THRESHOLD=7.5
LEAD_WARM_THRESHOLD=4.0
